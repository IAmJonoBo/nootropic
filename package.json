{
  "name": "nootropic",
  "version": "0.1.0",
  "description": "nootropic: Modular, ESM-only TypeScript toolkit for orchestrating, testing, and automating AI agent workflows. Optimized for LLM and agent integration.",
  "gptdoc": "nootropic/API/Usage: import { getOrchestrationEngine } from 'nootropic'; const engine = getOrchestrationEngine('langchain'); const result = await engine.runAgentTask({ name: 'TestAgent' }, { id: 't1', description: 'Say hello' }); console.log(result); // Use listCapabilities() to discover all helpers and plugins.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "bin": {
    "nootropic": "./agentOrchestrationCli.js"
  },
  "scripts": {
    "build": "tsc && pnpm run copy-non-ts",
    "copy-non-ts": "cpx \"adapters/**/*.{json,js,md}\" dist/adapters && cpx \"plugins/**/*.{json,js,md}\" dist/plugins && cpx \"quality/**/*.{json,js,md}\" dist/quality",
    "test": "vitest run",
    "update": "pnpm up nootropic",
    "quality": "tsx quality/index.ts",
    "validate-describe-registry": "pnpm tsx cliHandler.ts describe-registry-validate",
    "docs:api": "typedoc --options typedoc.json",
    "lint": "eslint scripts ./*.ts ./*.tsx --ext .ts,.tsx --report-unused-disable-directives",
    "docs:check-sync": "tsx scripts/docs-check-sync.ts",
    "ts-migrate": "ts-migrate migrate",
    "watch:registry": "tsx scripts/watchRegistryAndDocs.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "llm",
    "typescript",
    "esm",
    "tool-use",
    "automation",
    "plugin",
    "discovery"
  ],
  "author": "Rocketship Contributors",
  "license": "MIT",
  "devDependencies": {
    "@asyncapi/cli": "^3.1.1",
    "@dapr/dapr": "^3.5.2",
    "@eslint/js": "^9.27.0",
    "@octokit/rest": "^21.1.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.59.0",
    "@opentelemetry/core": "^2.0.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.201.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.201.0",
    "@opentelemetry/propagator-b3": "^2.0.1",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-metrics": "^2.0.1",
    "@opentelemetry/sdk-node": "^0.201.0",
    "@opentelemetry/semantic-conventions": "^1.33.0",
    "@sourcemeta/jsonschema": "^9.3.1",
    "@types/express": "^5.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^3.1.3",
    "ajv-cli": "^5.0.0",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "cpx2": "^8.0.0",
    "eslint": "^9.27.0",
    "eslint-plugin-tsdoc": "^0.4.0",
    "kafkajs": "^2.2.4",
    "knip": "^5.56.0",
    "nats": "^2.29.3",
    "node-fetch": "^3.3.2",
    "rrdir": "^13.2.1",
    "ts-migrate": "^0.1.35",
    "tsx": "^4.19.4",
    "typedoc": "^0.28.4",
    "typedoc-plugin-markdown": "^4.6.3",
    "typescript-eslint": "^8.32.1",
    "update-notifier": "^7.3.1",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.812.0",
    "@tensorflow-models/toxicity": "^1.2.2",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@xenova/transformers": "^2.17.2",
    "enquirer": "^2.4.1",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^4.0.5",
    "node-vault": "^0.10.2",
    "okapibm25": "^1.4.1",
    "ollama": "^0.5.15",
    "ws": "^8.18.2",
    "zod": "^3.24.4"
  }
}