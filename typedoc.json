{
  "entryPoints": [
    "index.ts",
    "agents/",
    "adapters/",
    "plugins/",
    "utils/",
    "types/"
  ],
  "out": "docs/api",
  "tsconfig": "tsconfig.json",
  "readme": "README.md",
  "theme": "default",
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "includeVersion": true,
  "plugin": ["typedoc-plugin-markdown"],
  "categorizeByGroup": true,
  "sort": ["source-order"],
  "validation": true
} 